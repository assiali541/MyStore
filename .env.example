# ==========================================
# MAISON LUXE - PRODUCTION ENV CONFIGURATION
# ==========================================

# ----------------------------
# Backend Server Configuration
# ----------------------------
# The port Express will listen on (automatically set by Railway)
PORT=8080
NODE_ENV=production

# JWT signing secret (change to a random secure string in production)
JWT_SECRET=your_jwt_signing_secret_here

# CORS configuration - Comma-separated list of allowed frontend origins
# E.g. ALLOWED_ORIGINS=https://luxe-store.up.railway.app,https://yourcustomdomain.com
ALLOWED_ORIGINS=*

# ----------------------------
# Database Configuration
# ----------------------------
# Primary database URL (supports MySQL/MariaDB)
# E.g. mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@host:3306/database

# Individual Railway database bindings (alternative fallback)
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# ----------------------------
# Frontend Configuration
# ----------------------------
# Vite SPA output asset path
BASE_PATH=/

# Production API Endpoint (Used by Vite production bundle build)
# Set this to your deployed Railway backend URL
VITE_API_BASE_URL=https://luxe-api.up.railway.app
